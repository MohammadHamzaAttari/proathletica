      "parameters": {
        "jsCode": "/**\n * Normalize + Validate Price\n *\n * Primary strategy: Scraper forces amazon.com/USD via locale cookies/headers.\n * The scraper attaches detectedCurrency to each product.\n *\n * This node:\n * 1. Rejects products where detectedCurrency is non-USD (locale enforcement failed)\n * 2. Parses USD prices directly — no conversion math needed\n * 3. Falls back to conversion ONLY as last resort with a warning\n * 4. Does NOT send source_currency — column does not exist in products table\n */\n\nlet response = $input.first().json;\n\nif (response && response.body) {\n  if (typeof response.body === 'string') {\n    try { response = JSON.parse(response.body); } catch (e) { response = {}; }\n  } else {\n    response = response.body;\n  }\n}\n\nif (Array.isArray(response)) response = response[0] || {};\n\nconst products = Array.isArray(response.products) ? response.products : [];\n\nconst niche = $('Split In Batches').item.json;\nconst category = niche.category || response.category || 'General';\nconst keyword = niche.keyword || response.keyword || '';\n\n// Emergency-only FX rates (last resort if locale enforcement failed)\nconst FX_TO_USD = {\n  USD: 1,\n  PKR: 1 / 280,\n  AED: 0.272294,\n  GBP: 1.27,\n  EUR: 1.08,\n  CAD: 0.73,\n  AUD: 0.66,\n  INR: 0.012,\n  SAR: 0.266667\n};\n\nfunction cleanUrl(value) {\n  const s = String(value || '').trim();\n  const md = s.match(/^\\[(https?:\\/\\/[^\\]]+)\\]\\((https?:\\/\\/[^)]+)\\)$/i);\n  if (md) return md[2];\n  return s;\n}\n\nfunction detectCurrency(raw) {\n  const s = String(raw || '').replace(/\\s+/g, ' ').trim();\n  if (/\\bPKR\\b|₨|Rs\\.?/i.test(s)) return 'PKR';\n  if (/\\bAED\\b|د\\.إ/i.test(s)) return 'AED';\n  if (/\\bGBP\\b/.test(s) || (/£/.test(s) && !/\\$/.test(s))) return 'GBP';\n  if (/\\bEUR\\b|€/.test(s)) return 'EUR';\n  if (/\\bCAD\\b|CA\\$/.test(s)) return 'CAD';\n  if (/\\bAUD\\b|AU\\$/.test(s)) return 'AUD';\n  if (/\\bINR\\b|₹/.test(s)) return 'INR';\n  if (/\\bSAR\\b|ر\\.س/.test(s)) return 'SAR';\n  if (/\\$|\\bUSD\\b/.test(s)) return 'USD';\n  return 'UNKNOWN';\n}\n\nfunction parsePriceToUsdCents(priceText, detectedCurrencyHint) {\n  const raw = String(priceText || '').replace(/\\s+/g, ' ').trim();\n  if (!raw) return null;\n  if (/price not available|currently unavailable|check latest price/i.test(raw)) return null;\n\n  const currency = (detectedCurrencyHint && detectedCurrencyHint !== 'UNKNOWN' && detectedCurrencyHint !== 'NONE')\n    ? detectedCurrencyHint\n    : detectCurrency(raw);\n\n  const numericText = raw.replace(/,/g, '');\n  const matches = [...numericText.matchAll(/\\d+(?:\\.\\d+)?/g)]\n    .map((m) => Number(m[0]))\n    .filter((n) => Number.isFinite(n) && n > 0);\n\n  if (matches.length === 0) return null;\n\n  const amount = Math.min(...matches);\n\n  if (currency !== 'USD') {\n    if (currency === 'UNKNOWN') {\n      if (amount > 500) {\n        return {\n          raw, sourceAmount: amount,\n          usdAmount: null, priceCents: null,\n          error: `Ambiguous price ${amount} with no currency symbol — too large to be USD`\n        };\n      }\n      const usdAmount = amount;\n      if (usdAmount < 1 || usdAmount > 999) return null;\n      return {\n        raw, sourceAmount: amount,\n        usdAmount, priceCents: Math.round(usdAmount * 100),\n        warning: 'No currency symbol — assumed USD'\n      };\n    }\n\n    const rate = FX_TO_USD[currency];\n    if (!rate) return {\n      raw, sourceAmount: amount,\n      usdAmount: null, priceCents: null,\n      error: `No FX rate for ${currency}`\n    };\n\n    const usdAmount = amount * rate;\n    if (!Number.isFinite(usdAmount) || usdAmount <= 0) return null;\n    if (usdAmount < 1 || usdAmount > 999) return null;\n\n    return {\n      raw, sourceAmount: amount,\n      usdAmount, priceCents: Math.round(usdAmount * 100),\n      warning: `LOCALE_ENFORCEMENT_FAILED: Scraped ${currency} ${amount}, converted to USD ${usdAmount.toFixed(2)}`\n    };\n  }\n\n  // Happy path: confirmed USD\n  if (!Number.isFinite(amount) || amount <= 0) return null;\n  if (amount < 1 || amount > 999) return null;\n\n  return {\n    raw, sourceAmount: amount,\n    usdAmount: amount, priceCents: Math.round(amount * 100)\n  };\n}\n\n// FIX: rating 0 from scraper means no rating found — store null\n// Valid Amazon ratings are 1.0–5.0\nfunction parseRating(value) {\n  const raw = String(value || '').trim();\n  if (!raw || raw === '0') return null;\n  const ratingRaw = parseFloat(raw.replace(/[^0-9.]/g, ''));\n  if (!Number.isFinite(ratingRaw) || ratingRaw < 1 || ratingRaw > 5) return null;\n  return ratingRaw;\n}\n\nfunction parseReviewCount(value) {\n  return parseInt(String(value || '0').replace(/[^0-9]/g, ''), 10) || 0;\n}\n\nfunction makeSlug(title, asin) {\n  const slug = String(title || '')\n    .toLowerCase()\n    .replace(/[^a-z0-9]+/g, '-')\n    .replace(/(^-|-$)/g, '')\n    .slice(0, 100);\n  return slug || String(asin || '').toLowerCase();\n}\n\nconst rows = [];\nconst rejected = [];\nconst currencyWarnings = [];\n\nfor (const [index, p] of products.entries()) {\n  const asin = String(p.asin || '').trim();\n  const title = String(p.title || '').trim();\n  const affiliateLink = cleanUrl(p.affiliateLink || p.affiliate_url || '');\n  const image = cleanUrl(p.image || p.image_url || '');\n\n  if (!asin) { rejected.push({ index, reason: 'missing asin' }); continue; }\n  if (!title) { rejected.push({ asin, reason: 'missing title' }); continue; }\n  if (!affiliateLink) { rejected.push({ asin, reason: 'missing affiliate link' }); continue; }\n  if (!image) { rejected.push({ asin, reason: 'missing image' }); continue; }\n\n  const priceInfo = parsePriceToUsdCents(\n    p.price || p.rawPrice || '',\n    p.detectedCurrency || null\n  );\n\n  if (!priceInfo || priceInfo.priceCents === null) {\n    rejected.push({\n      asin,\n      reason: priceInfo ? priceInfo.error : 'invalid/unparseable price',\n      price: p.price || p.rawPrice || '',\n      detectedCurrency: p.detectedCurrency || 'unknown'\n    });\n    continue;\n  }\n\n  if (priceInfo.warning) {\n    currencyWarnings.push({ asin, warning: priceInfo.warning });\n    console.warn(`⚠️ ${asin}: ${priceInfo.warning}`);\n  }\n\n  const description =\n    (typeof p.reviewSnippet === 'string' && p.reviewSnippet.trim()) ||\n    (Array.isArray(p.features) && p.features[0] && String(p.features[0]).trim()) ||\n    title;\n\n  // NOTE: source_currency is intentionally excluded — not a column in products table\n  rows.push({\n    json: {\n      id: asin,\n      asin,\n      slug: makeSlug(title, asin),\n      category,\n      subcategory: null,\n      brand: p.brand && String(p.brand).trim() ? String(p.brand).trim() : null,\n      title,\n      description,\n      keyword,\n      price_cents: priceInfo.priceCents,\n      currency: 'USD',\n      image_url: image,\n      affiliate_url: affiliateLink,\n      rating: parseRating(p.rating),\n      review_count: parseReviewCount(p.reviewCount),\n      badge: p.badge && String(p.badge).trim() ? String(p.badge).trim() : null,\n      rank: index + 1,\n      is_featured: index < 3,\n      last_scraped_at: new Date().toISOString()\n    }\n  });\n}\n\nif (rows.length === 0) {\n  return [{\n    json: {\n      _noValidProducts: true,\n      keyword, category, rejected, currencyWarnings,\n      reason: 'No valid products after validation. Check rejected for currency/price issues.'\n    }\n  }];\n}\n\nif (currencyWarnings.length > 0) {\n  console.warn('Currency warnings (locale enforcement may have failed):', JSON.stringify(currencyWarnings));\n}\n\nreturn rows;"
      },
